[run]
source = app
branch = true
omit =
    app/api/openapi.py
    */migrations/*

[report]
fail_under = 80
show_missing = true
skip_covered = true
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == .__main__.:
    \.\.\.
    raise NotImplementedError

[html]
directory = reports/coverage-html

[xml]
output = reports/coverage.xml
