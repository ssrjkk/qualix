# Копировать в .env и заполнить
DATABASE_URL=postgresql+asyncpg://qa:qa@localhost:5432/qa_sentinel
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP=localhost:9092
ENVIRONMENT=development
SECRET_KEY=change-me-to-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Для AI assertions в E2E тестах (опционально)
ANTHROPIC_API_KEY=

# Для авто-создания GitHub Issues при flaky тестах (опционально)
GITHUB_TOKEN=
CREATE_GH_ISSUES=0
