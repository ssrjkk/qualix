# SealedSecret — замена для plain Secret.
# Установка:
#   kubectl apply -f https://github.com/bitnami-labs/sealed-secrets/releases/latest/download/controller.yaml
#
# Создание зашифрованного SealedSecret:
#   kubeseal --format=yaml < infra/k8s/secret.yaml > infra/k8s/sealed-secret.yaml.example
#
# Применение (расшифровывается только Sealed Secrets controller):
#   kubectl apply -f infra/k8s/sealed-secret.yaml.example
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: qa-sentinel-secret
  namespace: qa-sentinel
  annotations:
    sealedsecrets.bitnami.com/namespace-wide: "true"
spec:
  encryptedData:
    # Замени на реальные зашифрованные значения после kubeseal
    DATABASE_URL: AgAA...
    REDIS_URL: AgAA...
    SECRET_KEY: AgAA...
  template:
    metadata:
      name: qa-sentinel-secret
      namespace: qa-sentinel
    type: Opaque
